###< Настройки проекта 
PROJECT_NAME=PP_ML_PLATFORM
VERSION=0.1.0
DEBUG=False
SESSIONS_SECRET_KEY=change_me_in_production_please
TEMP_DIR=var/temp
MAX_FILE_SIZE=10485760
APP_PORT=8000
###> Настройки проекта

###< Настройки логирования
LOG_LEVEL=INFO
LOG_DIR=var/log
###> Настройки логирования

###< Настройки Yandex S3 (Object Storage)
# Получить в консоли Yandex Cloud -> Service Accounts -> Создать статический ключ доступа
YA_S3_ACCESS_KEY_ID=key_id
YA_S3_SECRET_ACCESS_KEY=key
YA_S3_BUCKET_NAME=bucket_name
###> Настройки Yandex S3

###< Настройки ML Service
TRANSLATOR_NAME=glazzova/translation_en_ru
TRANSLATOR_TYPE=marian
TRANSLATOR_DEVICE=cpu # "cpu" или "cuda" или "mps"

RECOGNIZER_NAME=medium
RECOGNIZER_DEVICE=cpu # "cpu" или "cuda"

OCR_DEVICE=cpu # "cpu" или "cuda" или "mps"
ML_CLI_SOURCE_PATH=var/data/input.mp4 # относительный путь от корня проекта, запуск: python -m src.command.ml_service
FFMPEG_BINARY= # опционально: абсолютный путь, например /opt/homebrew/bin/ffmpeg
FFPROBE_BINARY= # опционально: если ffprobe лежит не рядом с ffmpeg
###> Настройки ML Service
